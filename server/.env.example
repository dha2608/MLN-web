PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/philosophy
SESSION_SECRET=your-strong-random-session-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
FRONTEND_URL=https://your-app.vercel.app
NODE_ENV=production

# ─── Local development ───
# MONGODB_URI=mongodb://localhost:27017/philosophy
# FRONTEND_URL=http://localhost:5173
# NODE_ENV=development

# ─── Google OAuth ───
# In Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Add redirect URI: https://your-render-app.onrender.com/api/auth/google/callback
# For local: http://localhost:4000/api/auth/google/callback
